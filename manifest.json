{
  "manifest_version": 3,
  "name": "AI Chess Assistant",
  "short_name": "ChessAI",
  "version": "4.0.0",
  "description": "Chrome extension for real-time chess analysis on chess.com",
  "author": "KGECMD",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": "assets/icon-48.png",
    "default_title": "AI Chess Assistant",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": [
        "https://www.chess.com/*",
        "https://chess.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://*.chess.com/*"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://chess.com/*"
  ]
}
